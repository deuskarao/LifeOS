// LifeOS - Comprehensive Life Management Database Schema
// Finans, Emlak ve Araç yönetimi için tek nokta çözüm
//
// SUPABASE KULLANIMI:
//   Supabase (PostgreSQL) için prisma/schema.supabase.prisma dosyasını kullanın:
//   1. cp prisma/schema.supabase.prisma prisma/schema.prisma
//   2. .env dosyasındaki DATABASE_URL'i Supabase connection string ile değiştirin
//   3. bun run db:push
//   4. bun run prisma/seed.ts
//   Detaylı talimat: .env.example dosyasına bakın.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ====================== FINANCE ======================

model BankAccount {
  id             String   @id @default(cuid())
  bankName       String
  accountName    String
  accountType    String   @default("Vadesiz") // Vadesiz, Vadeli, Birikim, Nakit
  balance        Float    @default(0)
  iban           String?
  easyAddress    String?
  holderName     String?
  expectedAmount Float    @default(0)
  color          String   @default("#3b82f6")
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model CreditCard {
  id           String   @id @default(cuid())
  bankName     String
  cardName     String
  cardType     String   @default("Visa") // Visa, Mastercard, Troy
  limit        Float    @default(0)
  balance      Float    @default(0) // kullanılan limit
  cutoffDay    Int      @default(1) // hesap kesim günü
  dueDay       Int      @default(15) // son ödeme günü
  color        String   @default("#8b5cf6")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Loan {
  id               String   @id @default(cuid())
  loanName         String
  lender           String
  principalAmount  Float    @default(0)
  remainingAmount  Float    @default(0)
  interestRate     Float    @default(0)
  monthlyPayment   Float    @default(0)
  startDate        DateTime
  endDate          DateTime?
  installmentsTotal Int     @default(0)
  installmentsPaid Int      @default(0)
  category         String   @default("İhtiyaç") // İhtiyaç, Konut, Taşıt, Ticari
  description      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Asset {
  id          String   @id @default(cuid())
  assetType   String   // Altın, Döviz, Hisse, Kripto, Fon, Diğer
  name        String
  quantity    Float    @default(0)
  unitPrice   Float    @default(0)
  totalValue  Float    @default(0)
  currency    String   @default("TRY")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Income {
  id         String   @id @default(cuid())
  source     String
  amount     Float    @default(0)
  currency   String   @default("TRY")
  category   String   @default("Maaş") // Maaş, Kira, Yatırım, Freelance, Diğer
  date       DateTime @default(now())
  recurring  Boolean  @default(false)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Expense {
  id            String   @id @default(cuid())
  category      String   // Market, Fatura, Yakıt, Kira, Eğlence, Sağlık, Diğer
  amount        Float    @default(0)
  currency      String   @default("TRY")
  date          DateTime @default(now())
  paymentMethod String   @default("Nakit") // Nakit, Kart, Havale
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ====================== REAL ESTATE ======================

model Property {
  id            String   @id @default(cuid())
  name          String
  type          String   @default("Daire") // Daire, Villa, Dükkan, Arsa, Ofis
  address       String?
  city          String?
  purchasePrice Float    @default(0)
  currentValue  Float    @default(0)
  monthlyRent   Float    @default(0)
  status        String   @default("Boş") // Kiralı, Boş, Satılık
  size          Float?   // m2
  rooms         String?  // 2+1, 3+1
  notes         String?
  contracts     RentalContract[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model RentalContract {
  id          String   @id @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenantName  String
  tenantPhone String?
  tenantEmail String?
  monthlyRent Float    @default(0)
  startDate   DateTime
  endDate     DateTime?
  deposit     Float    @default(0)
  status      String   @default("Aktif") // Aktif, Bitti, Beklemede
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ====================== VEHICLES ======================

model Vehicle {
  id         String   @id @default(cuid())
  name       String
  plate      String?
  brand      String?
  model      String?
  year       Int?
  fuelType   String   @default("Benzin") // Benzin, Dizel, LPG, Hibrit, Elektrik
  currentKm  Int      @default(0)
  color      String?
  notes      String?
  fuelRecords  VehicleFuel[]
  serviceRecords VehicleService[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model VehicleFuel {
  id        String   @id @default(cuid())
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  date      DateTime @default(now())
  liters    Float    @default(0)
  amount    Float    @default(0)
  km        Int      @default(0)
  fuelType  String   @default("Benzin")
  station   String?
  createdAt DateTime @default(now())
}

model VehicleService {
  id          String   @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  date        DateTime @default(now())
  serviceType String   // Periyodik Bakım, Yağ Değişimi, Lastik, Sigorta, Muayene, Diğer
  amount      Float    @default(0)
  km          Int      @default(0)
  notes       String?
  createdAt   DateTime @default(now())
}
